[Unit]
Description=Herdres Tendwire source Telegram sync loop

[Service]
Type=simple
EnvironmentFile=%h/.config/herdres/herdres.env
Environment=HERDRES_TENDWIRE_MODE=source
Environment=HERDRES_INBOUND_LANES=1
ExecStart=%h/.local/bin/herdres sync --loop 5
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
