<?xml version="1.0" encoding="UTF-8"?>
<!-- Template: install-macos.sh replaces __HOME__ with $HOME. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gaijinjoe.herdres</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.local/share/herdres/herdres-sync.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>5</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>__HOME__/.local/share/herdres/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.local/share/herdres/launchd.err.log</string>
</dict>
</plist>
