# Required
# Tip: `herdres setup` fills these in for you — it prompts, validates, runs
# preflight, and writes ~/.config/herdres/herdres.env at mode 0600 (and refuses
# to silently reuse another app's bot token).
TELEGRAM_BOT_TOKEN=
HERDR_TELEGRAM_TOPICS_CHAT_ID=
TELEGRAM_ALLOWED_USERS=

# Usually optional
HERDR_BIN=herdr
HERDR_TELEGRAM_TOPICS_STATE=~/.local/share/herdres/state.json
HERDR_TELEGRAM_TOPICS_LOCK=~/.local/share/herdres/sync.lock
HERDR_TELEGRAM_TOPICS_SCRIPT=~/.local/bin/herdres
HERDR_TELEGRAM_TOPICS_GENERAL_THREAD_ID=1
HERDR_TELEGRAM_TOPICS_PLUGIN_EVENTS=1
HERDR_TELEGRAM_TOPICS_EVENT_SETTLE_SECONDS=4
HERDR_TELEGRAM_TOPICS_EVENT_SETTLE_INTERVAL=0.75
HERDR_TELEGRAM_TOPICS_DUPLICATE_DELETE_LIMIT=12
# Cleanup hardening (#79): abandon a topic after this many consecutive non-"gone" delete failures
# (429/permission/transient) so a stuck topic can't be retried every sync and re-pin the lock.
HERDR_TELEGRAM_TOPICS_CLEANUP_FAIL_ATTEMPT_LIMIT=3
# Tier-0 stale-state prune: drop state records whose topic is already audited-gone (no Telegram call).
HERDR_TELEGRAM_TOPICS_TIER0_PRUNE=1

# Optional Tendwire integration mode. Values: off (default), enrich, commands,
# source-read, source. enrich adds Tendwire metadata/status to unambiguous real
# Herdr pane matches while sending text directly to Herdr. commands and higher
# keep that enrichment and route normal Telegram text for enriched targets through
# tendwire command --json. source-read/source are not otherwise implemented here.
# Invalid mode values warn and fall back to off.
# Legacy compatibility: when HERDRES_TENDWIRE_MODE is unset,
# HERDRES_TENDWIRE_HYBRID=1 or HERDRES_TENDWIRE_SNAPSHOT=1 aliases to enrich.
HERDRES_TENDWIRE_MODE=off
HERDRES_TENDWIRE_HYBRID=0
HERDRES_TENDWIRE_SNAPSHOT=0
# Tendwire command to run. If the first token is path-like, Herdres expands ~
# and environment variables while preserving any extra shlex-style arguments.
HERDRES_TENDWIRE_BIN=tendwire
# Outer wall-clock timeout for the Tendwire CLI subprocess.
HERDRES_TENDWIRE_TIMEOUT_SECONDS=5
# Inner Herdr probe timeout passed through to Tendwire as TENDWIRE_HERDR_TIMEOUT_SECONDS.
# Keep this below HERDRES_TENDWIRE_TIMEOUT_SECONDS so Tendwire can fail cleanly.
HERDRES_TENDWIRE_HERDR_TIMEOUT_SECONDS=1.0
# Optional Tendwire-specific overrides. Leave unset to let Tendwire use its own defaults.
# HERDRES_TENDWIRE_DATA_DIR=~/.local/share/tendwire
# HERDRES_TENDWIRE_DB_PATH=~/.local/share/tendwire/tendwire.sqlite3
# HERDRES_TENDWIRE_HOST_ID=
HERDRES_TENDWIRE_FALLBACK_HERDR=1
# Emergency operator override: after Tendwire command routing is selected, direct
# Herdr fallback stays off unless this is explicitly set to 1.
HERDRES_TENDWIRE_DIRECT_FALLBACK=0
# Optional Tendwire connector outbox drain. Default off for staged rollout. When
# enabled, sync polls the neutral attention queue, posts public-safe notices to
# General, then ack/fail/defer with opaque Tendwire refs only.
HERDRES_TENDWIRE_CONNECTOR_OUTBOX=0
HERDRES_TENDWIRE_CONNECTOR_NAME=attention
HERDRES_TENDWIRE_CONNECTOR_LIMIT=3
HERDRES_TENDWIRE_CONNECTOR_LEASE_SECONDS=60
HERDRES_TENDWIRE_CONNECTOR_FAILURE_DELAY_SECONDS=60

# Rate/overhead bounds
HERDR_TELEGRAM_TOPICS_MAX_CREATES=3
HERDR_TELEGRAM_TOPICS_MAX_SENDS=8
HERDR_TELEGRAM_TOPICS_MAX_STATUS_MARKERS=8
HERDR_TELEGRAM_TOPICS_FEED_READ_LINES=140
HERDR_TELEGRAM_TOPICS_FEED_MAX_CHARS=9000
HERDR_TELEGRAM_TOPICS_STREAMING=1
HERDR_TELEGRAM_TOPICS_STREAM_MIN_INTERVAL=2
HERDR_TELEGRAM_TOPICS_STREAM_MIN_CHARS=80
HERDR_TELEGRAM_TOPICS_MAX_DRAFTS=8

# Managed child bots. Herdres suggests only child bots for currently open pane
# agent types, then stores tokens from Telegram managed_bot updates.
HERDR_TELEGRAM_TOPICS_MANAGED_BOTS=1
# Optional JPG profile photos for child bots. Telegram profile photos must be
# fresh uploaded JPG files.
HERDR_TELEGRAM_TOPICS_MANAGED_BOT_CODEX_PHOTO=
HERDR_TELEGRAM_TOPICS_MANAGED_BOT_CLAUDE_PHOTO=
HERDR_TELEGRAM_TOPICS_MANAGED_BOT_KIMI_PHOTO=
HERDR_TELEGRAM_TOPICS_MANAGED_BOT_OMP_PHOTO=
HERDR_TELEGRAM_TOPICS_MANAGED_BOT_DEVIN_PHOTO=
HERDR_TELEGRAM_TOPICS_MANAGED_BOT_GLM_PHOTO=
# Optional manual child-bot token assignment. Use this when the bot was created
# outside Telegram's managed-bot request flow.
# HERDR_TELEGRAM_TOPICS_MANAGED_BOT_GLM_TOKEN=
# HERDR_TELEGRAM_TOPICS_MANAGED_BOT_GLM_USERNAME=Guremi_bot
# HERDR_TELEGRAM_TOPICS_MANAGED_BOT_GLM_NAME=Guremi

# Gateway polling. Each manager/child bot token gets its own long-poll worker.
HERDRES_GATEWAY_LONG_POLL_SECONDS=50
HERDRES_GATEWAY_CHILD_POLL_SECONDS=0
HERDRES_GATEWAY_NETWORK_ERROR_BACKOFF=0.5
HERDRES_GATEWAY_DISPATCH_WORKERS=8
HERDRES_GATEWAY_DISPATCH_QUEUE_LIMIT=128
# embedded avoids spawning Python for every inbound Telegram update. Set to
# subprocess to force the older cold-process path while debugging.
HERDRES_GATEWAY_RUNNER=embedded

# /new <agent> pane launcher commands. Override if your CLI names differ.
HERDR_TELEGRAM_TOPICS_NEW_PANE_CODEX_COMMAND=codex
HERDR_TELEGRAM_TOPICS_NEW_PANE_CLAUDE_COMMAND=claude
HERDR_TELEGRAM_TOPICS_NEW_PANE_KIMI_COMMAND=kimi
HERDR_TELEGRAM_TOPICS_NEW_PANE_OMP_COMMAND=omp
HERDR_TELEGRAM_TOPICS_NEW_PANE_DEVIN_COMMAND=devin

# Legacy explicit opt-in Devin GLM seat provisioner. When enabled, each Herdr
# space gets one extra pane launched through Devin using GLM 5.2. Prefer
# `/new glm-5.2` for user-driven seats; manual panes are independent.
# If you close/remove an auto seat, Herdres leaves it closed. Set RECREATE=1
# to restore legacy continuous recreation.
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_SEAT=0
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_SEAT_RECREATE=0
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_MODEL=glm-5.2
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_PERMISSION_MODE=dangerous
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_LABEL=GLM Devin
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_SEAT_MAX_PER_RUN=1
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_SEAT_PENDING_TTL=1800
HERDR_TELEGRAM_TOPICS_DEVIN_GLM_SEAT_ERROR_RETRY=300
# HERDR_TELEGRAM_TOPICS_DEVIN_GLM_COMMAND=
# HERDR_TELEGRAM_TOPICS_DEVIN_GLM_EXTRA_ARGS=
# /new kimi-k2.7 launches Kimi through Devin.
# HERDR_TELEGRAM_TOPICS_DEVIN_KIMI_LABEL=Kimi Devin
# HERDR_TELEGRAM_TOPICS_DEVIN_KIMI_COMMAND=
# HERDR_TELEGRAM_TOPICS_DEVIN_KIMI_EXTRA_ARGS=

# Default structured-turn integration. This avoids parsing terminal transcripts.
# Requires: herdr pane turn <pane_id> --last --format json
HERDR_TELEGRAM_TOPICS_TURN_FEED=1
# Local adapter mode, when Herdr does not expose pane turn yet:
# HERDR_BIN=/home/smith/.local/bin/herdr_turn_adapter.py
# HERDR_REAL_BIN=/home/smith/.local/bin/herdr
# Issue #3: while a turn is open/streaming, the worklog header reads "Working…" instead of
# "Worklog" so the topic shows the agent is alive. Set to 0 to keep the plain "Worklog" label.
HERDR_TELEGRAM_TOPICS_WORKING_BADGE=1
# Issue #44: native Telegram "typing…" animation on a topic while its pane is actively working.
# Refreshed ~every 4s by herdres-gateway (so it needs the gateway running); self-clears when the
# pane goes idle. Set to 1 to enable.
HERDR_TELEGRAM_TOPICS_TYPING_ACTION=0
# Issue #4: local, on-box voice (speech-to-text in, text-to-speech out) via sherpa-onnx (parakeet +
# Kokoro) — a two-way "call" with your agent over Telegram. Machine-agnostic; opt-in; fail-open (any
# speech failure degrades to text). Run `herdres speech install` once to fetch the models + deps.
# v1: transcribe an owner's voice note into the pane. NOTE: in v1 (no sidecar yet) transcription runs
# in-process while the gateway holds its lock, so a voice note briefly (~a few seconds, dominated by
# the first-use model load) pauses routing for other panes; the v2 warm sidecar removes this.
HERDR_TELEGRAM_TOPICS_SPEECH_INPUT=0
# Cap the transcribed audio length (seconds) so a long note can't tie up transcription. Default 600.
HERDR_TELEGRAM_TOPICS_SPEECH_MAX_SECONDS=600
# Echo "🎙️ Heard: …" into the topic so you can see/correct what was transcribed (on by default).
HERDR_TELEGRAM_TOPICS_SPEECH_ECHO_TRANSCRIPT=1
# v2: speak the agent's reply back as a Telegram voice message (Kokoro TTS). A spoken reply is a
# short trimmed version of the final answer (code stripped); the full text turn is unchanged.
# PER-MESSAGE opt-in: include this phrase in your prompt (typed or spoken) and just THAT reply is
# spoken back; default stays text. No global flag needed. Set to "" to disable the keyword.
HERDR_TELEGRAM_TOPICS_SPEECH_REPLY_TRIGGER=reply by voice
# Force-speak EVERY reply on every pane (a global override; leave 0 — the trigger above is safer).
HERDR_TELEGRAM_TOPICS_SPEECH_REPLIES=0
HERDR_TELEGRAM_TOPICS_SPEECH_REPLY_MAX_CHARS=600
HERDR_TELEGRAM_TOPICS_SPEECH_TTS_SID=0   # Kokoro voice/speaker id (0-10 for kokoro-en-v0_19)
# Spoken replies REQUIRE the warm sidecar (it synthesizes asynchronously, off the sync lock):
#   systemctl --user enable --now herdres-speech.service   (after `herdres speech install`)
# The sidecar also keeps STT warm. Inbound STT still works without it (in-process, slower; v1 note above).
# Model ids (downloaded into HERDR_TELEGRAM_TOPICS_SPEECH_MODELS_DIR, default ~/.local/share/herdres/speech-models).
HERDR_TELEGRAM_TOPICS_SPEECH_STT_MODEL=parakeet-tdt-0.6b-v3-int8
HERDR_TELEGRAM_TOPICS_SPEECH_TTS_MODEL=kokoro-en-v0_19
HERDR_TELEGRAM_TOPICS_FINAL_REPLY_MAX_CHARS=16000
HERDR_TELEGRAM_TOPICS_FINAL_REPLY_MAX_LINES=140
HERDR_TELEGRAM_TOPICS_USER_PROMPT_MAX_CHARS=1200
HERDR_TELEGRAM_TOPICS_INPUT_FILE_CHARS=1200
HERDR_TELEGRAM_TOPICS_INPUT_FILE_LINES=6
HERDR_TELEGRAM_TOPICS_INPUT_FILE_MAX_CHARS=120000
# Safe choice handling. Structured pending_decision and explicit HERDRES_CHOICES
# still render buttons. Inferred buttons from visible TUI choices are disabled
# because Claude multi-question/review wizards cannot be safely key-driven.
HERDR_TELEGRAM_TOPICS_VISIBLE_CHOICE_BUTTONS=0
# Show visible TUI prompts read-only when structured turn data is unavailable.
# This never creates buttons, ForceReply state, or key-driving callbacks.
HERDR_TELEGRAM_TOPICS_VISIBLE_READONLY_PROMPTS=1
# Legacy inferred choices are off by default. Structured pending_decision and
# explicit HERDRES_CHOICES blocks still render buttons.
HERDR_TELEGRAM_TOPICS_LEGACY_CHOICES=0
HERDR_TELEGRAM_TOPICS_STRUCTURED_INTERACTIONS=1
HERDR_TELEGRAM_TOPICS_ACTIVE_PROMPT_TTL=900

# Topic granularity. Default (0) maps one forum topic per Herdr space/workspace.
# Set to 1 to map one forum topic per Herdr agent (pane), named "<agent> · <folder>"
# (or the manual pane label if set). Toggling this triggers a one-time clean-slate
# reset: Herdres forgets existing topic mappings and creates fresh per-agent topics
# (old topics are left in place on Telegram for you to delete).
HERDR_TELEGRAM_TOPICS_PER_AGENT=0

# Rich-first behavior
HERDR_TELEGRAM_TOPICS_RICH_MESSAGES=1
HERDR_TELEGRAM_TOPICS_RICH_MAX_CHARS=14000
HERDR_TELEGRAM_TOPICS_LIVE_CARD=1
HERDR_TELEGRAM_TOPICS_PANE_ROOT_MESSAGES=0

# Optional pinned "all panes" status overview (Codex 🟢 | Claude 🟡 | ...).
# Off by default. When enabled you MUST point it at an existing forum topic id
# (it never uses General and never auto-creates a topic).
HERDR_TELEGRAM_TOPICS_PINNED_STATUS=0
HERDR_TELEGRAM_TOPICS_PINNED_STATUS_TOPIC_ID=
HERDR_TELEGRAM_TOPICS_STATUS_ICON=1
HERDR_TELEGRAM_TOPICS_STATUS_ICON_CACHE_TTL=86400
HERDR_TELEGRAM_TOPICS_STATUS_ICON_RETRY=300
HERDR_TELEGRAM_TOPICS_STATUS_MARKER_SUPPRESS_WHEN_ICON_OK=1
# Optional explicit Telegram forum icon custom emoji IDs. If unset, Herdres
# tries getForumTopicIconStickers and matches by the *_EMOJI values below.
HERDR_TELEGRAM_TOPICS_STATUS_ICON_WORKING=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_IDLE=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_DONE=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_BLOCKED=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_ERROR=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_WORKFLOW=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_UNKNOWN=
HERDR_TELEGRAM_TOPICS_STATUS_ICON_WORKING_EMOJI=⚡️
HERDR_TELEGRAM_TOPICS_STATUS_ICON_IDLE_EMOJI=☕️
HERDR_TELEGRAM_TOPICS_STATUS_ICON_DONE_EMOJI=✅
HERDR_TELEGRAM_TOPICS_STATUS_ICON_BLOCKED_EMOJI=❗️
HERDR_TELEGRAM_TOPICS_STATUS_ICON_ERROR_EMOJI=‼️
HERDR_TELEGRAM_TOPICS_STATUS_ICON_WORKFLOW_EMOJI=📈
HERDR_TELEGRAM_TOPICS_STATUS_ICON_UNKNOWN_EMOJI=❓
HERDR_TELEGRAM_TOPICS_STATUS_MARKER=0
HERDR_TELEGRAM_TOPICS_STATUS_MARKER_DELETE_OLD=1

# Local testing without Telegram writes
HERDR_TELEGRAM_TOPICS_DRY_RUN=0
