# Herdres tendwired branch: Tendwire source-mode Telegram connector only.

HERDRES_TENDWIRE_MODE=source

# Telegram manager bot used for sending, editing, topic creation, and inbound polling.
TELEGRAM_BOT_TOKEN=
HERDRES_TELEGRAM_CHAT_ID=

# Existing Herdres state. The state can contain Telegram topic/message IDs and is private.
HERDR_TELEGRAM_TOPICS_STATE=~/.local/share/herdres/state.json
HERDR_TELEGRAM_TOPICS_SCRIPT=~/.local/bin/herdres
HERDR_TELEGRAM_TOPICS_GENERAL_THREAD_ID=1

# Telegram topic granularity for source mode:
#   space  = one topic per Tendwire space/project (default)
#   worker = one topic per Tendwire worker/pane
HERDRES_SOURCE_TOPIC_MODE=space

# Finished council/gitmoot/gm worker topics are deleted automatically.
HERDRES_DELETE_DONE_COUNCIL_TOPICS=1

# Tendwire store and optional source checkout fallback when no `tendwire` binary exists.
HERDRES_TENDWIRE_DB_PATH=~/.local/share/tendwire/tendwire.db
TENDWIRE_DB_PATH=~/.local/share/tendwire/tendwire.db
# TENDWIRE_SOURCE_DIR=~/tendwire/src
# HERDRES_TENDWIRE_BIN=tendwire

# Gateway polling.
HERDRES_GATEWAY_LONG_POLL_SECONDS=50
HERDRES_GATEWAY_NETWORK_ERROR_BACKOFF=1
HERDRES_GATEWAY_COMMAND_TIMEOUT=90
