# Herdres tendwired branch: Tendwire source-mode Telegram connector only.

HERDRES_TENDWIRE_MODE=source

# Telegram manager bot used for sending, editing, topic creation, and inbound polling.
TELEGRAM_BOT_TOKEN=
HERDRES_TELEGRAM_CHAT_ID=

# Rich Telegram message rendering is enabled by default. Set to 0 only if your
# bot/API surface does not support rich messages and you need plain fallback.
HERDR_TELEGRAM_TOPICS_RICH_MESSAGES=1
# Minimum seconds between edits of the same in-progress Working card. Final
# responses are not delayed by this.
HERDR_TELEGRAM_TOPICS_WORKING_UPDATE_MIN_SECONDS=30

# Optional per-agent bot identity/routing. Keep real tokens in your private env
# or state; do not commit them. Supported generic kinds: codex, claude, glm,
# kimi, omp, devin.
# Use /voice shared or /voice per_agent inside a space topic to switch that space.
HERDR_TELEGRAM_TOPICS_MANAGED_BOTS=0
# HERDRES_MANAGED_BOT_CODEX_TOKEN=
# HERDRES_MANAGED_BOT_CLAUDE_TOKEN=
# HERDRES_MANAGED_BOT_GLM_TOKEN=
# HERDRES_MANAGED_BOT_KIMI_TOKEN=
# HERDRES_MANAGED_BOT_OMP_TOKEN=
# HERDRES_MANAGED_BOT_DEVIN_TOKEN=

# Optional inbound Telegram voice-note transcription. This is local/offline STT
# via sherpa-onnx + ffmpeg; disabled by default.
HERDR_TELEGRAM_TOPICS_SPEECH_INPUT=0
# HERDR_TELEGRAM_TOPICS_SPEECH_MODELS_DIR=~/.local/share/herdres/speech-models
# HERDR_TELEGRAM_TOPICS_SPEECH_STT_MODEL=parakeet-tdt-0.6b-v3-int8

# Existing Herdres state. It can contain private Telegram topic/message IDs,
# bot tokens and routing/ownership, final bindings, and stable-job checkpoints
# and receipts. Retain it across restart and never publish it.
HERDR_TELEGRAM_TOPICS_STATE=~/.local/share/herdres/state.json

# Path to the dedicated private raw 32-byte HMAC key for stable Telegram ingress
# request IDs. Unset or empty uses ~/.local/share/herdres/request-id.key. A
# configured value expands ~ and must then be a nonempty absolute path.
# install-user.sh creates the key once (owner directory 0700, owner-owned
# regular file 0600) and preserves it. Put only the path here, never key bytes.
HERDRES_REQUEST_ID_KEY_PATH=~/.local/share/herdres/request-id.key
# Fixed first-seen retry horizon: unset, empty, or invalid uses 86400;
# configured values clamp to 60..604800. Retry, redelivery, updated_at, and
# later config changes never slide deadline_at; equality quarantines and
# advances with a cached fixed safe reply. retain_until is also first-seen
# based: effective horizon + 86400 (172800 default, 86460 minimum, 691200
# maximum), pruned only after equality. Pair Tendwire retry >= this horizon and
# Tendwire receipt retention >= this bound; Tendwire defaults
# 604800/2592000 seconds plus newest 4096 inactive receipts satisfy the pair.
HERDRES_COMMAND_RETRY_HORIZON_SECONDS=86400
HERDR_TELEGRAM_TOPICS_SCRIPT=~/.local/bin/herdres
HERDR_TELEGRAM_TOPICS_GENERAL_THREAD_ID=1

# Durable per-topic inbound lanes are enabled by default. Set this to 0 only
# for an explicit legacy synchronous rollback. Telegram updates and their
# receiving-bot cursors commit atomically to a separate FULL-synchronous SQLite
# WAL before getUpdates advances. One head runs per lane, with up to 8 lanes in
# parallel; a full lane drops only the new item and posts one throttled notice.
HERDRES_INBOUND_LANES=1
# HERDRES_INBOUND_SPOOL_PATH=~/.local/share/herdres/inbound_spool.db
HERDRES_INBOUND_DISPATCH_WORKERS=8
HERDRES_INBOUND_LANE_DEPTH=32
HERDRES_INBOUND_LANE_BACKOFF_SECONDS=2
# Structured receive -> enqueue -> claim -> canonical -> submit -> receipt logs.
HERDRES_GATEWAY_TIMING_LOGS=1

# Telegram topic granularity for source mode:
#   space  = one topic per Tendwire space/project (default)
#   worker = one topic per Tendwire worker/pane
HERDRES_SOURCE_TOPIC_MODE=space

# Clean up worker/pane topics after their entry has remained closed for this
# many hours. Retired churn archives use the same TTL. "close" is reversible;
# "delete" removes the topic and a revived UUID-owned pane gets a freshly
# created topic. 0 disables new cleanup. Telegram calls run off-lock and are
# bounded twice.
HERDRES_CLOSE_DORMANT_AFTER_HOURS=24
HERDRES_TOPIC_CLEANUP_ACTION=close
HERDRES_CLEANUP_BUDGET_SECONDS=5
HERDRES_CLEANUP_MAX_OPS=12

# Post the pinned status board(s): a global agent/model overview pinned in the
# General topic, plus a per-topic status line showing the selected model. 0 = off.
# Turning it off only stops updating the boards; any already-pinned board stays
# pinned frozen at its last content, so set this off before first run (or unpin
# the boards by hand) to avoid a stale board that looks like live status.
HERDRES_PINNED_STATUS=1

# Append a who-am-I/quota footer to the pinned boards: plan tier from the local CLI
# credential files (named metadata fields only — never tokens) plus the REMAINING 5h and
# weekly rate-limit headroom, e.g. "🔑 Max 20x · 5h 76% left (1h10m) · wk 68% left (Sun)".
# Claude reads the OAuth usage endpoint (what in-app /usage shows); Codex reads the
# rate_limits events in its local session logs. Degrades to no line when the sources are
# absent. 0 = off.
HERDRES_PINNED_ACCOUNT=1

# Disk-cache TTL (seconds) for the quota snapshot behind the account footer. Coarse on
# purpose: every refresh can change the footer and re-edit every pinned board, so this is
# the pin-edit rate limiter.
HERDRES_USAGE_REFRESH_SECONDS=300

# Reply with a "Sent to Tendwire worker" ack after each successful inbound send.
# 0 = suppress it, so you only see the agent's working + response messages.
# Send FAILURES are still reported either way.
HERDRES_ACK_ON_SEND=1

# Render safe, structured Claude AskUserQuestion / ExitPlanMode prompts,
# including bounded multi-select questions, as inline Telegram controls.
# Default on; 0 leaves the ordinary attention notice in place and requires
# answering at the desk. A concurrent answer keeps the keyboard and replies
# that the prompt is being answered now so the owner can tap again later.
HERDRES_REMOTE_DECISIONS=1

# Finished council/gitmoot/gm worker topics are deleted automatically.
HERDRES_DELETE_DONE_COUNCIL_TOPICS=1

# Tendwire store and optional source checkout fallback when no `tendwire` binary exists.
HERDRES_TENDWIRE_DB_PATH=~/.local/share/tendwire/tendwire.db
TENDWIRE_DB_PATH=~/.local/share/tendwire/tendwire.db
# TENDWIRE_SOURCE_DIR=~/tendwire/src
# HERDRES_TENDWIRE_BIN=tendwire
# Public Tendwire call timeout and bounded Goal 13 change-page size.
HERDRES_TENDWIRE_TIMEOUT_SECONDS=60
HERDRES_TENDWIRE_DELTA_LIMIT=500
# Optional dual-contract command receipts. Keep 2 for older Tendwire; set 3 to
# request deterministic submission handles while still accepting v2 replies.
HERDRES_TENDWIRE_COMMAND_RESPONSE_SCHEMA_VERSION=2
# Safety-net full reconciliation cadence. Zero, negative, or invalid values use
# the 3600-second default; force one explicit run with the flag below.
HERDRES_TENDWIRE_FULL_RECONCILE_SECONDS=3600
# HERDRES_TENDWIRE_FORCE_FULL_RECONCILE=0
# Bounds recovery after an ambiguous connector poll response. Unset, empty, or
# invalid values use 60 seconds; configured values clamp to 60..3600 seconds.
HERDRES_TENDWIRE_TURN_FINAL_LEASE_SECONDS=60

# Gateway polling.
HERDRES_GATEWAY_LONG_POLL_SECONDS=50
# 0 means child bots use the same long-poll timeout as the manager bot.
HERDRES_GATEWAY_CHILD_POLL_SECONDS=0
HERDRES_GATEWAY_NETWORK_ERROR_BACKOFF=1
HERDRES_GATEWAY_COMMAND_TIMEOUT=90
